# Copy to .env and adjust. PostgreSQL must be running (e.g. Docker).
# DATABASE_URL is used by Alembic (sync); app uses DATABASE_URL_ASYNC or default below.

# Optional: override app database URL (async driver for FastAPI)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Optional: explicit async URL for the app (defaults to postgresql+asyncpg://...)
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/postgres

# Optional
# DEBUG=false
# HOST=0.0.0.0
# PORT=8000
